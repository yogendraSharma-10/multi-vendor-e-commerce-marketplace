# This file is an example. Create a .env file in the same directory and add your environment variables.
# DO NOT commit the .env file to your version control system.

# --- Application Environment ---
# Set to 'development', 'production', or 'test'
NODE_ENV=development

# --- Server Configuration ---
# The port the Node.js server will listen on
PORT=5000

# --- Database Configuration (MongoDB Example) ---
# Connection string for your MongoDB database.
# For local development: mongodb://127.0.0.1:27017/marketplace_db
# For production (e.g., MongoDB Atlas): mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_CONNECTION_STRING=mongodb://127.0.0.1:27017/marketplace_db_dev

# --- Authentication & Security ---
# A long, random, and secret string used for signing JSON Web Tokens (JWTs).
# Generate a secure secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_that_is_very_long_and_random
# How long a JWT should be valid for (e.g., 1h, 7d, 30m)
JWT_EXPIRES_IN=7d

# Secret for signing cookies, if you use cookie-based sessions
COOKIE_SECRET=your_super_secret_cookie_key_for_sessions

# --- CORS Configuration ---
# The origin URL of your React client application.
# For local development, this is typically http://localhost:3000
CLIENT_URL=http://localhost:3000

# --- Payment Gateway (Stripe Example) ---
# Your Stripe publishable and secret keys.
# Find these in your Stripe developer dashboard.
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Secret for verifying Stripe webhook signatures to ensure events are from Stripe.
# Find this in your Stripe dashboard's webhook settings.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# --- Email Service (SendGrid Example) ---
# API key for your email service provider to send transactional emails (e.g., order confirmation, password reset).
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# The email address that transactional emails will be sent from.
EMAIL_FROM="Marketplace Support <support@yourmarket.com>"

# --- File Storage (AWS S3 Example) ---
# Credentials for your cloud storage provider (e.g., for product images).
# In production, it's highly recommended to use IAM roles for EC2/ECS instead of hardcoding keys.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your-marketplace-bucket-name
AWS_REGION=us-east-1

# --- Rate Limiting ---
# Optional: Configure rate limiting to prevent API abuse.
# Maximum number of requests per window per IP.
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=200