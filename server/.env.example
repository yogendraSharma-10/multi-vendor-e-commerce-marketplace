# -----------------------------------------------------------------------------
# General Application Configuration
# -----------------------------------------------------------------------------
# Set the environment for the application. Can be 'development', 'production', or 'test'.
NODE_ENV=development

# The port the Node.js server will listen on.
PORT=5000

# -----------------------------------------------------------------------------
# Database Configuration (MongoDB)
# -----------------------------------------------------------------------------
# The connection string for your MongoDB database.
# Example for local MongoDB: mongodb://127.0.0.1:27017/marketplace_dev
# Example for MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_CONNECTION_STRING=mongodb://127.0.0.1:27017/marketplace_dev

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
# A long, complex, and random string used to sign JSON Web Tokens.
# Generate a strong secret using a tool like `openssl rand -base64 32`.
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_characters_long

# How long a token is valid for. Examples: '1h', '7d', '30m'.
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) Configuration
# -----------------------------------------------------------------------------
# The URL of your React client application. This is required to allow the
# frontend to make requests to the backend API.
# For multiple origins, separate them with a comma (e.g., http://localhost:3000,https://your-production-domain.com)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Payment Gateway (Stripe)
# -----------------------------------------------------------------------------
# Your Stripe publishable key (safe to expose on the client-side).
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Your Stripe secret key (NEVER expose this on the client-side).
STRIPE_SECRET_KEY=sk_test_...

# Your Stripe webhook signing secret, used to verify events from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Email Service (SMTP)
# -----------------------------------------------------------------------------
# Configuration for sending transactional emails (e.g., order confirmation, password reset).
# Example for Mailtrap (testing), SendGrid, Mailgun, etc.
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM="Marketplace Support <support@example.com>"

# -----------------------------------------------------------------------------
# File/Image Storage (e.g., Cloudinary, AWS S3)
# -----------------------------------------------------------------------------
# Credentials for a cloud storage service to handle vendor product images.
# Using a service like this is recommended over storing files on the server filesystem.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------------------------------------------------------------------
# PHP Admin Panel Database Configuration
# -----------------------------------------------------------------------------
# These variables are for the PHP admin panel's database connection.
# They might connect to the same database as the Node.js app but are
# listed here for clarity as the PHP app will need its own config file.
ADMIN_DB_HOST=127.0.0.1
ADMIN_DB_USER=root
ADMIN_DB_PASS=password
ADMIN_DB_NAME=marketplace_dev