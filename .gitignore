# =============================================================================
# General & System Files
# =============================================================================

# Operating System Files
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
__MACOSX

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# IDE and Editor Configuration
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
*.sublime-project
*.sublime-workspace
.history/

# =============================================================================
# Project-Specific
# =============================================================================

# Environment variables
# Use .env.example as a template for your local environment variables.
# Never commit secrets or credentials.
.env
.env.*
!.env.example
!.env.test

# Log files
logs/
*.log
*.log.*

# Temporary files
*.tmp
*.temp
*.swp

# =============================================================================
# Node.js / JavaScript (for /server and /client)
# =============================================================================

# Dependency directories
# These are installed via `npm install` or `yarn install`
node_modules/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test and coverage reports
coverage/
.nyc_output/

# Lock files - It's generally best practice to commit these for consistent builds.
# Uncomment if your project policy is to not commit them.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# =============================================================================
# React Client (/client)
# =============================================================================

# Build output directory for the React app
client/build/

# =============================================================================
# Node.js Server (/server)
# =============================================================================

# Build output directory if using a transpiler like TypeScript or Babel
server/dist/
server/build/

# =============================================================================
# PHP / Composer (/admin-panel)
# =============================================================================

# Composer dependencies directory
admin-panel/vendor/

# Composer executable downloaded locally
composer.phar

# Local configuration files that may contain sensitive data
admin-panel/config.local.php

# =============================================================================
# Docker
# =============================================================================

# Ignore local docker-compose override files
docker-compose.override.yml
docker-compose.override.yaml

# Ignore local data volumes if mounted in the project root
# (Adjust path if necessary)
# db-data/
# cache-data/